{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PLUGIN_ROOT/scripts/acgm-hook.sh\" session-start \"$CLAUDE_PLUGIN_DATA\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PLUGIN_ROOT/scripts/acgm-hook.sh\" pretool-bash \"$CLAUDE_PLUGIN_DATA\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PLUGIN_ROOT/scripts/acgm-hook.sh\" pretool-write \"$CLAUDE_PLUGIN_DATA\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PLUGIN_ROOT/scripts/acgm-hook.sh\" posttool \"$CLAUDE_PLUGIN_DATA\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PLUGIN_ROOT/scripts/acgm-hook.sh\" posttool-failure \"$CLAUDE_PLUGIN_DATA\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PLUGIN_ROOT/scripts/acgm-hook.sh\" stop \"$CLAUDE_PLUGIN_DATA\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PLUGIN_ROOT/scripts/acgm-hook.sh\" session-end \"$CLAUDE_PLUGIN_DATA\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
